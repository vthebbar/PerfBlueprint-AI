# ==============================================================================
# PerfBlueprint - Streamlined Environment Configuration
# Save this file exactly as ".env" or "env" in your project's root directory.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Core Application Configurations
# ------------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 2. Active Selection Strategy
# ------------------------------------------------------------------------------
# Options: "Google Gemini" | "Anthropic" | "OpenAI Compatible / Custom"
AI_PROVIDER=Google Gemini

# ------------------------------------------------------------------------------
# 3. Google Gemini Pillar
# ------------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=gemini-api-key

# ------------------------------------------------------------------------------
# 4. Anthropic Pillar
# ------------------------------------------------------------------------------
ANTHROPIC_MODEL=claude-opus-4.7
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# 5. OpenAI Compatible / Custom Pillar (Groq, DeepSeek, Ollama, xAI, etc.)
# ------------------------------------------------------------------------------
# Change these dynamically using the UI or update here to point to any custom provider.
AI_MODEL=llama-3.3-70b-versatile
CUSTOM_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=ai-api-key
