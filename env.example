# ==============================================================================
# PerfBlueprint - Environment Configuration
# Save this file exactly as ".env" or "env" in your project's root directory.
# WARNING: Contains sensitive credentials. Never commit this file to source control!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Core Application Configurations
# ------------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 2. Universal & Dedicated AI API Credentials
# ------------------------------------------------------------------------------
# The UI will dynamically target and update these lines. Keep these placeholders 
# exactly where they are so the tool updates them inline without breaking comments.

# Common Key: Shared across OpenAI, DeepSeek, xAI Grok, and OpenRouter
AI_API_KEY=your_common_ai_api_key_here

# Dedicated Keys: Required for native provider platform SDKs
GEMINI_API_KEY=you_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------------------------
# 3. Custom AI Endpoint Base URLs
# ------------------------------------------------------------------------------
# Base URLs used by Ollama and OpenAI-compatible provider routing networks.

OLLAMA_BASE_URL=http://localhost:11434/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
XAI_BASE_URL=https://api.x.ai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_PROVIDER=OpenRouter
GEMINI_MODEL=gemini-2.5-flash
